{
  "name": "instancio-js",
  "version": "1.3.0",
  "description": "Dynamically generate TypeScript/JavaScript objects for testing. Inspired by Instancio",
  "author": "Dorian Naaji",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doriannaaji/instancio-js.git"
  },
  "bugs": {
    "url": "https://github.com/doriannaaji/instancio-js/issues"
  },
  "keywords": [
    "random javascript object",
    "random typescript object",
    "generate javascript objects",
    "generate typescript objects",
    "instancio for javascript",
    "instancio for typescript",
    "javascript random object generator",
    "typescript random object generator"
  ],
  "homepage": "https://github.com/doriannaaji/instancio-js#readme",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "typegen generate && node esbuild.build.js && node dist/index.js",
    "build": "typegen generate && node esbuild.build.js",
    "test": "typegen generate && vitest",
    "prepare": "husky",
    "format": "prettier --write ."
  },
  "files": [
    "dist"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "esbuild": "0.25.6",
    "esbuild-plugin-rttist": "^0.19.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "typescript": "5.8.3",
    "vite-plugin-rttist": "^6.0.0",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@rttist/typegen": "^0.2.0",
    "random-string-generator": "^1.0.7",
    "rttist": "^1.0.0-beta.8"
  }
}
