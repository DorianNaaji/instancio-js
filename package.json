{
  "name": "instancio-js",
  "version": "2.2.0",
  "description": "Test data generator for TypeScript and JavaScript. Auto-populate objects and interfaces with random values for unit tests. Inspired by Instancio for Java",
  "author": "Dorian Naaji",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doriannaaji/instancio-js.git"
  },
  "bugs": {
    "url": "https://github.com/doriannaaji/instancio-js/issues"
  },
  "keywords": [
    "test-data-generator",
    "test-fixtures",
    "mock-data",
    "fake-data",
    "faker",
    "typescript",
    "javascript",
    "testing",
    "unit-test",
    "random",
    "object-generation",
    "interface-generation",
    "instancio",
    "instancio-js"
  ],
  "homepage": "https://github.com/doriannaaji/instancio-js#readme",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepare": "ts-patch install && husky",
    "start": "ts-node -P tsconfig.build.json src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest",
    "test:jest": "npm run build && jest",
    "deploy": "npm run build && npm publish",
    "format": "prettier --write ."
  },
  "files": [
    "dist"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/jest": "^29.5.14",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-patch": "3.3.0",
    "typescript": "6.0.3",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "random-string-generator": "^1.0.7",
    "reflect-metadata": "^0.1.14",
    "tslib": "^2.8.1"
  },
  "devDependenciesComments": {
    "@rollup/plugin-typescript": "Used for allowing vitest to build with custom typescript transformers.",
    "vitest": "Test framework"
  },
  "dependenciesComments": {
    "tslib": "required dependency for compiling the lib",
    "reflect-metadata": "Reflection lib which instancio-js relies on"
  }
}
